<Window x:Class="MinecraftHost.Views.BuildSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:MinecraftHost.Localization"
        Title="{x:Static loc:Texts.Xaml_BuildSelection_Title}"
        Height="480"
        Width="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <TextBlock Text="{x:Static loc:Texts.Xaml_BuildSelection_BuildNumber}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
        </Border>

        <ListBox x:Name="BuildIdentifiersList"
                 Grid.Row="1"
                 Margin="10"
                 ItemsSource="{Binding BuildIdentifiers}"
                 SelectedItem="{Binding SelectedBuild, Mode=TwoWay}"
                 Background="Transparent"
                 BorderThickness="0"
                 FontFamily="Consolas"
                 FontSize="13"/>

        <Border Grid.Row="2"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="0,1,0,0"
                Padding="10,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{x:Static loc:Texts.Xaml_Common_Cancel}"
                        Style="{StaticResource BtnSecondary}"
                        Click="OnCancel"
                        Margin="0,0,8,0"
                        Padding="12,6"/>
                <Button Content="{x:Static loc:Texts.Xaml_Common_Apply}"
                        Style="{StaticResource BtnPrimary}"
                        Click="OnApply"
                        Padding="12,6"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>