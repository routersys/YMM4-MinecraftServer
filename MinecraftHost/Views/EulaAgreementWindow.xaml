<Window x:Class="MinecraftHost.Views.EulaAgreementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:MinecraftHost.Localization"
        Title="{x:Static loc:Texts.Xaml_Eula_Title}"
        Height="360"
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MainPageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center">
            <TextBlock Text="{x:Static loc:Texts.Xaml_Eula_Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>
            <TextBlock Text="{x:Static loc:Texts.Xaml_Eula_Message}" TextWrapping="Wrap" Margin="0,0,0,16" FontSize="14" LineHeight="22"/>

            <TextBlock Margin="0,0,0,8" FontSize="14">
                <Hyperlink NavigateUri="https://www.minecraft.net/ja-jp/eula" RequestNavigate="Hyperlink_RequestNavigate">
                    <Run Text="{x:Static loc:Texts.Xaml_Eula_MinecraftEula}"/>
                </Hyperlink>
            </TextBlock>
            <TextBlock FontSize="14">
                <Hyperlink NavigateUri="https://www.microsoft.com/ja-jp/privacy/privacystatement" RequestNavigate="Hyperlink_RequestNavigate">
                    <Run Text="{x:Static loc:Texts.Xaml_Eula_PrivacyStatement}"/>
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="{x:Static loc:Texts.Xaml_Eula_Agree}" Command="{Binding AgreeCommand}" Width="120" Height="36" Margin="0,0,12,0" Style="{StaticResource BtnPrimary}"/>
            <Button Content="{x:Static loc:Texts.Xaml_Eula_Decline}" Command="{Binding DeclineCommand}" Width="120" Height="36" Style="{StaticResource BtnSecondary}"/>
        </StackPanel>
    </Grid>
</Window>