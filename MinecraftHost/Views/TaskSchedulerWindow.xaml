<Window x:Class="MinecraftHost.Views.TaskSchedulerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:vm="clr-namespace:MinecraftHost.ViewModels.Windows"
        xmlns:loc="clr-namespace:MinecraftHost.Localization"
        xmlns:sched="clr-namespace:MinecraftHost.Models.Scheduler"
        Title="{x:Static loc:Texts.Xaml_Scheduler_Title}"
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
        FontFamily="Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MainPageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="12" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding AddTaskCommand}" Style="{StaticResource BtnPrimary}" Content="{x:Static loc:Texts.Xaml_Scheduler_Add}" Padding="12,6"/>
                        <Button Command="{Binding DeleteTaskCommand}" Style="{StaticResource BtnDanger}" Content="{x:Static loc:Texts.Xaml_Scheduler_Delete}" Padding="12,6" Margin="10,0,0,0"/>
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="1" ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                         Style="{StaticResource SideListBox}" ItemContainerStyle="{StaticResource SideListBoxItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Rectangle Width="10" Height="10" Margin="0,0,8,0">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Fill" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                    <Setter Property="Fill" Value="#3FB950"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding DisplayMode}" FontSize="11" Opacity="0.75" Margin="0,3,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel DataContext="{Binding SelectedTask}" Margin="20">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="{x:Static loc:Texts.Xaml_Scheduler_Name}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtSystem}" Margin="0,0,0,15"/>

                <CheckBox Content="{x:Static loc:Texts.Xaml_Scheduler_Enabled}" IsChecked="{Binding IsEnabled, Mode=TwoWay}" Margin="0,0,0,15"/>

                <TextBlock Text="{x:Static loc:Texts.Xaml_Scheduler_Mode}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding DataContext.ScheduleModes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedValue="{Binding Mode, Mode=TwoWay}" SelectedValuePath="Value" DisplayMemberPath="Display" Style="{StaticResource CmbSystem}" Margin="0,0,0,15"/>

                <StackPanel Margin="0,0,0,15">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Mode}" Value="{x:Static sched:ScheduleMode.Interval}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{x:Static loc:Texts.Xaml_Scheduler_IntervalSeconds}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding IntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtSystem}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Mode}" Value="{x:Static sched:ScheduleMode.SpecificDate}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{x:Static loc:Texts.Xaml_Scheduler_SpecificDate}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding SpecificDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                BorderBrush="{DynamicResource {x:Static SystemColors.WindowFrameBrushKey}}"
                                BorderThickness="1"
                                Padding="4">
                        <DatePicker.Resources>
                            <Style TargetType="DatePickerTextBox">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"/>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Mode}" Value="{x:Static sched:ScheduleMode.Daily}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Mode}" Value="{x:Static sched:ScheduleMode.Weekly}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Mode}" Value="{x:Static sched:ScheduleMode.SpecificDate}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{x:Static loc:Texts.Xaml_Scheduler_TimeOfDay}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding TimeOfDay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtSystem}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Mode}" Value="{x:Static sched:ScheduleMode.Weekly}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{x:Static loc:Texts.Xaml_Scheduler_DayOfWeek}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding DataContext.DaysOfWeek, RelativeSource={RelativeSource AncestorType=Window}}" SelectedValue="{Binding DayOfWeek, Mode=TwoWay}" SelectedValuePath="Value" DisplayMemberPath="Display" Style="{StaticResource CmbSystem}"/>
                </StackPanel>

                <TextBlock Text="{x:Static loc:Texts.Xaml_Scheduler_FilePath}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="..." Command="{Binding SelectFileCommand}" Width="26" Height="26" Margin="0,0,5,0" Focusable="False" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtSystem}"/>
                </Grid>

                <TextBlock Text="{x:Static loc:Texts.Xaml_Scheduler_Arguments}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtSystem}" Margin="0,0,0,15"/>

                <TextBlock Text="{x:Static loc:Texts.Xaml_Scheduler_TargetType}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <CheckBox Content="{x:Static loc:Texts.Xaml_Scheduler_TargetAll}" IsChecked="{Binding TargetAllServers, Mode=TwoWay}" Margin="0,0,0,10"/>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TargetAllServers}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{x:Static loc:Texts.Xaml_Scheduler_TargetSpecific}" Margin="0,0,0,5"/>
                    <ListBox ItemsSource="{Binding AvailableServers}" MaxHeight="150" BorderThickness="1" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>