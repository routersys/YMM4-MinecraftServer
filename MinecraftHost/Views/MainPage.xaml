<UserControl x:Class="MinecraftHost.Views.MainPage"
             x:Name="RootControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MinecraftHost.Behaviors"
             xmlns:vm="clr-namespace:MinecraftHost.ViewModels.Items"
             xmlns:vmp="clr-namespace:MinecraftHost.ViewModels.Pages"
             xmlns:models="clr-namespace:MinecraftHost.Models.Logging"
             xmlns:conv="clr-namespace:MinecraftHost.Converters"
             xmlns:loc="clr-namespace:MinecraftHost.Localization"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="680" d:DesignWidth="980"
             Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
             Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
             FontFamily="Segoe UI"
             FontSize="13"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DataContext="{d:DesignInstance Type=vmp:MainPageViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MainPageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:WidthThresholdConverter x:Key="WidthThresholdConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition>
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="220"/>
                        <Setter Property="MinWidth" Value="160"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:980}" Value="True">
                                <Setter Property="Width" Value="0"/>
                                <Setter Property="MinWidth" Value="0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition>
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="4"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:980}" Value="True">
                                <Setter Property="Width" Value="0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:980}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Padding="12,10"
                    BorderBrush="{DynamicResource {x:Static SystemColors.WindowFrameBrushKey}}" BorderThickness="0,0,0,1">
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Viewbox Width="15" Height="15" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Path Data="{StaticResource GServer}" Fill="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" Stretch="Uniform"/>
                    </Viewbox>
                    <TextBlock Text="{x:Static loc:Texts.Xaml_Main_ServerManager}"
                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Servers}"
                     SelectedItem="{Binding SelectedServer, Mode=TwoWay}"
                     Style="{StaticResource SideListBox}"
                     ItemContainerStyle="{StaticResource SideListBoxItem}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ServerItemViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
                                <TextBlock FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Opacity="0.75" Margin="0,3,0,0" TextTrimming="CharacterEllipsis">
                                    <Run Text="{Binding ServerType, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding Version, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <Rectangle Grid.Column="1"
                                       Width="6" Height="6"
                                       Fill="#3FB950"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Row="2" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Padding="0"
                    BorderBrush="{DynamicResource {x:Static SystemColors.WindowFrameBrushKey}}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="DesktopCreateButton"
                            Grid.Column="0"
                            Command="{Binding CreateServerCommand}"
                            ToolTip="{Binding CreateServerDeniedReason}"
                            ToolTipService.ShowOnDisabled="True"
                            Style="{StaticResource BtnPrimary}"
                            BorderThickness="0"
                            Margin="0"
                            FontSize="12" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Path Data="{StaticResource GPlus}" Fill="White" Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock Text="{x:Static loc:Texts.Xaml_Main_CreateNew}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1"
                            Command="{Binding DeleteServerCommand}"
                            ToolTip="{Binding DeleteServerDeniedReason}"
                            ToolTipService.ShowOnDisabled="True"
                            Style="{StaticResource BtnDanger}"
                            Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                            BorderThickness="0"
                            Margin="0"
                            FontSize="12" Padding="0">
                        <Viewbox Width="15" Height="15">
                            <Path Data="{StaticResource GTrash}" Fill="White" Stretch="Uniform"/>
                        </Viewbox>
                    </Button>
                    <Button Grid.Column="2"
                            Command="{Binding OpenSchedulerCommand}"
                            ToolTip="{x:Static loc:Texts.Xaml_Main_OpenScheduler}"
                            Style="{StaticResource BtnAction}"
                            Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                            BorderThickness="0"
                            Margin="0"
                            FontSize="12" Padding="0">
                        <Viewbox Width="15" Height="15">
                            <Path Data="M8,16C12.418,16 16,12.418 16,8C16,3.582 12.418,0 8,0C3.582,0 0,3.582 0,8C0,12.418 3.582,16 8,16ZM8,1.5C11.589,1.5 14.5,4.411 14.5,8C14.5,11.589 11.589,14.5 8,14.5C4.411,14.5 1.5,11.589 1.5,8C1.5,4.411 4.411,1.5 8,1.5ZM8.5,3.5L7.5,3.5L7.5,8L11,10.61L11.5,9.81L8.5,7.6L8.5,3.5Z" Fill="White" Stretch="Uniform"/>
                        </Viewbox>
                    </Button>
                    <Button Grid.Column="3"
                            Command="{Binding OpenOperationsCenterCommand}"
                            ToolTip="{Binding OpenOperationsCenterDeniedReason}"
                            ToolTipService.ShowOnDisabled="True"
                            Style="{StaticResource BtnAction}"
                            Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                            BorderThickness="0"
                            Margin="0"
                            FontSize="12" Padding="0">
                        <Viewbox Width="15" Height="15">
                            <Path Data="{StaticResource GCpu}" Fill="White" Stretch="Uniform"/>
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" Cursor="SizeWE"
                      ResizeBehavior="PreviousAndNext">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:980}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </GridSplitter.Style>
        </GridSplitter>

        <Grid DataContext="{Binding SelectedServer}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Setter Property="Grid.Column" Value="2"/>
                    <Setter Property="Grid.ColumnSpan" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:980}" Value="True">
                            <Setter Property="Grid.Column" Value="0"/>
                            <Setter Property="Grid.ColumnSpan" Value="3"/>
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding}" Value="{x:Null}"/>
                                <Condition Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=ge:980}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Hidden"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" Padding="12,10"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <ToggleButton x:Name="MobileSidebarButton"
                                      Width="30"
                                      Height="30"
                                      Padding="0"
                                      Background="Transparent"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      Tag="{Binding DataContext, ElementName=RootControl}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Opacity" Value="0.8"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:980}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                            <Viewbox Width="15" Height="15" VerticalAlignment="Center">
                                <Path Data="{StaticResource GMenu}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                            </Viewbox>
                        </ToggleButton>
                        <Popup PlacementTarget="{Binding ElementName=MobileSidebarButton}"
                               Placement="Bottom"
                               StaysOpen="False"
                               PopupAnimation="None"
                               IsOpen="{Binding IsChecked, ElementName=MobileSidebarButton, Mode=TwoWay}"
                               DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                            <Border Width="280"
                                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                            Padding="12,10"
                                            BorderBrush="{DynamicResource {x:Static SystemColors.WindowFrameBrushKey}}"
                                            BorderThickness="0,0,0,1">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Viewbox Width="15" Height="15" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Path Data="{StaticResource GServer}" Fill="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" Stretch="Uniform"/>
                                            </Viewbox>
                                            <TextBlock Text="{x:Static loc:Texts.Xaml_Main_ServerManager}"
                                                       Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding Servers}"
                                             SelectedItem="{Binding SelectedServer, Mode=TwoWay}"
                                             Style="{StaticResource SideListBox}"
                                             ItemContainerStyle="{StaticResource SideListBoxItem}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:ServerItemViewModel}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
                                                        <TextBlock FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Opacity="0.75" Margin="0,3,0,0" TextTrimming="CharacterEllipsis">
                                                            <Run Text="{Binding ServerType, Mode=OneWay}"/>
                                                            <Run Text=" · "/>
                                                            <Run Text="{Binding Version, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <Rectangle Grid.Column="1"
                                                               Width="6" Height="6"
                                                               Fill="#3FB950"
                                                               Margin="8,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Border Grid.Row="2" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Padding="0"
                                            BorderBrush="{DynamicResource {x:Static SystemColors.WindowFrameBrushKey}}" BorderThickness="0,1,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="PopupCreateButton"
                                                    Grid.Column="0"
                                                    Command="{Binding CreateServerCommand}"
                                                    ToolTip="{Binding CreateServerDeniedReason}"
                                                    ToolTipService.ShowOnDisabled="True"
                                                    Style="{StaticResource BtnPrimary}"
                                                    BorderThickness="0"
                                                    Margin="0"
                                                    FontSize="12" Padding="8,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center">
                                                        <Path Data="{StaticResource GPlus}" Fill="White" Stretch="Uniform"/>
                                                    </Viewbox>
                                                    <TextBlock Text="{x:Static loc:Texts.Xaml_Main_CreateNew}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="1"
                                                    Command="{Binding DeleteServerCommand}"
                                                    ToolTip="{Binding DeleteServerDeniedReason}"
                                                    ToolTipService.ShowOnDisabled="True"
                                                    Style="{StaticResource BtnDanger}"
                                                    Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                                                    BorderThickness="0"
                                                    Margin="0"
                                                    FontSize="12" Padding="0">
                                                <Viewbox Width="15" Height="15">
                                                    <Path Data="{StaticResource GTrash}" Fill="White" Stretch="Uniform"/>
                                                </Viewbox>
                                            </Button>
                                            <Button Grid.Column="2"
                                                    Command="{Binding OpenSchedulerCommand}"
                                                    ToolTip="{x:Static loc:Texts.Xaml_Main_OpenScheduler}"
                                                    Style="{StaticResource BtnAction}"
                                                    Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                                                    BorderThickness="0"
                                                    Margin="0"
                                                    FontSize="12" Padding="0">
                                                <Viewbox Width="15" Height="15">
                                                    <Path Data="M8,16C12.418,16 16,12.418 16,8C16,3.582 12.418,0 8,0C3.582,0 0,3.582 0,8C0,12.418 3.582,16 8,16ZM8,1.5C11.589,1.5 14.5,4.411 14.5,8C14.5,11.589 11.589,14.5 8,14.5C4.411,14.5 1.5,11.589 1.5,8C1.5,4.411 4.411,1.5 8,1.5ZM8.5,3.5L7.5,3.5L7.5,8L11,10.61L11.5,9.81L8.5,7.6L8.5,3.5Z" Fill="White" Stretch="Uniform"/>
                                                </Viewbox>
                                            </Button>
                                            <Button Grid.Column="3"
                                                    Command="{Binding OpenOperationsCenterCommand}"
                                                    ToolTip="{Binding OpenOperationsCenterDeniedReason}"
                                                    ToolTipService.ShowOnDisabled="True"
                                                    Style="{StaticResource BtnAction}"
                                                    Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                                                    BorderThickness="0"
                                                    Margin="0"
                                                    FontSize="12" Padding="0">
                                                <Viewbox Width="15" Height="15">
                                                    <Path Data="{StaticResource GCpu}" Fill="White" Stretch="Uniform"/>
                                                </Viewbox>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Popup>
                    </StackPanel>
                    <Grid Grid.Column="1">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,8" Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:500}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                            <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="1" Padding="8,4" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12" Height="12" Margin="0,0,5,0">
                                        <Path Data="{StaticResource GCpu}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                                    </Viewbox>
                                    <TextBlock Text="{Binding CpuUsage}" Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" FontSize="12"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="1" Padding="8,4" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12" Height="12" Margin="0,0,5,0">
                                        <Path Data="{StaticResource GMemory}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                                    </Viewbox>
                                    <TextBlock Text="{Binding MemoryUsage}" Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" FontSize="12"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="1" Padding="8,4">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12" Height="12" Margin="0,0,5,0">
                                        <Path Data="{StaticResource GPerson}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                                    </Viewbox>
                                    <TextBlock Text="{Binding PlayerCount}" Foreground="#3FB950" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                        </StackPanel>

                        <WrapPanel Grid.Row="1" Orientation="Horizontal">
                            <WrapPanel.Resources>
                                <Style x:Key="CompactInputToggle" TargetType="ToggleButton">
                                    <Setter Property="Width" Value="30"/>
                                    <Setter Property="Height" Value="30"/>
                                    <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.WindowFrameBrushKey}}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Margin" Value="0,0,6,0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style x:Key="WideFieldVisibility" TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:850}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                                <Style x:Key="WideMemoryFieldVisibility" TargetType="StackPanel" BasedOn="{StaticResource WideFieldVisibility}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBedrockServer}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                                <Style x:Key="CompactMemoryFieldVisibility" TargetType="ToggleButton" BasedOn="{StaticResource CompactInputToggle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBedrockServer}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </WrapPanel.Resources>

                            <StackPanel Width="150" Margin="0,0,8,0">
                                <TextBlock Text="{x:Static loc:Texts.Xaml_Main_Name}" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" FontSize="11" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtSystem}" IsEnabled="{Binding IsNotRunning}"/>
                            </StackPanel>

                            <StackPanel Width="115" Margin="0,0,8,0" Style="{StaticResource WideFieldVisibility}">
                                <TextBlock Text="{x:Static loc:Texts.Xaml_Main_Type}" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" FontSize="11" Margin="0,0,0,3"/>
                                <ComboBox ItemsSource="{Binding Source={StaticResource ServerTypeEnum}}" SelectedItem="{Binding ServerType}" Style="{StaticResource CmbSystem}" IsEnabled="{Binding IsNotRunning}"/>
                            </StackPanel>

                            <StackPanel Width="265" Margin="0,0,8,0" Style="{StaticResource WideFieldVisibility}">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="{x:Static loc:Texts.Xaml_Main_Version}" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" FontSize="11"/>
                                    <Button Command="{Binding SelectBuildCommand}" Style="{StaticResource BtnSecondary}" Padding="0" Margin="6,0,0,0" Visibility="{Binding IsBuildSelectionAvailable, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding CurrentBuildDisplay}" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" FontSize="11"/>
                                    </Button>
                                    <TextBlock Text="{x:Static loc:Texts.Xaml_Main_Loading}" Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" FontSize="11" Visibility="{Binding IsLoadingVersions, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Command="{Binding UseLatestVersionCommand}" Style="{StaticResource BtnUpdate}" Height="28" Padding="7,0" Margin="4,0,0,0" ToolTip="{Binding UpdateMessage}" Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Viewbox Width="10" Height="10" Margin="0,0,4,0" VerticalAlignment="Center">
                                                <Path Data="{StaticResource GArrowUp}" Fill="#FFD580" Stretch="Uniform"/>
                                            </Viewbox>
                                            <TextBlock Text="{Binding UpdateTargetDisplay}" FontSize="10" VerticalAlignment="Center" Foreground="#FFD580"/>
                                        </StackPanel>
                                    </Button>
                                    <ComboBox ItemsSource="{Binding AvailableVersions}"
                                              SelectedItem="{Binding Version}"
                                              Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True"
                                              Style="{StaticResource CmbSystem}"
                                              IsEnabled="{Binding IsNotRunning}"
                                              local:ComboBoxIncrementalLoadingBehavior.LoadMoreCommand="{Binding LoadMoreVersionsCommand}"/>
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Width="105" Margin="0,0,8,0" Style="{StaticResource WideMemoryFieldVisibility}">
                                <TextBlock Text="{x:Static loc:Texts.Xaml_Main_MemoryMb}" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" FontSize="11" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding MaxMemoryMB, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtSystem}" IsEnabled="{Binding IsNotRunning}"/>
                            </StackPanel>

                            <StackPanel Width="85" Style="{StaticResource WideMemoryFieldVisibility}">
                                <TextBlock Text="{x:Static loc:Texts.Xaml_Main_Port}" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" FontSize="11" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtSystem}" IsEnabled="{Binding IsNotRunning}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,17,8,0" VerticalAlignment="Top">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:850}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <ToggleButton x:Name="TypeInputToggle" Style="{StaticResource CompactInputToggle}">
                                    <Viewbox Width="15" Height="15">
                                        <Path Data="{StaticResource GServer}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                                    </Viewbox>
                                </ToggleButton>
                                <Popup PlacementTarget="{Binding ElementName=TypeInputToggle}" Placement="Bottom" PopupAnimation="None" StaysOpen="False" IsOpen="{Binding IsChecked, ElementName=TypeInputToggle, Mode=TwoWay}">
                                    <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.WindowFrameBrushKey}}" BorderThickness="1" Padding="8" Width="200">
                                        <StackPanel>
                                            <TextBlock Text="{x:Static loc:Texts.Xaml_Main_Type}" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" FontSize="11" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{Binding Source={StaticResource ServerTypeEnum}}" SelectedItem="{Binding ServerType}" Style="{StaticResource CmbSystem}" IsEnabled="{Binding IsNotRunning}"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                <ToggleButton x:Name="VersionInputToggle" Style="{StaticResource CompactInputToggle}">
                                    <Viewbox Width="15" Height="15">
                                        <Path Data="{StaticResource GArrowUp}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                                    </Viewbox>
                                </ToggleButton>
                                <Popup PlacementTarget="{Binding ElementName=VersionInputToggle}" Placement="Bottom" PopupAnimation="None" StaysOpen="False" IsOpen="{Binding IsChecked, ElementName=VersionInputToggle, Mode=TwoWay}">
                                    <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.WindowFrameBrushKey}}" BorderThickness="1" Padding="8" Width="300">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{x:Static loc:Texts.Xaml_Main_Version}" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" FontSize="11"/>
                                                <Button Command="{Binding SelectBuildCommand}" Style="{StaticResource BtnSecondary}" Padding="0" Margin="6,0,0,0" Visibility="{Binding IsBuildSelectionAvailable, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{Binding CurrentBuildDisplay}" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" FontSize="11"/>
                                                </Button>
                                            </StackPanel>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Command="{Binding UseLatestVersionCommand}" Style="{StaticResource BtnUpdate}" Height="28" Padding="7,0" Margin="4,0,0,0" ToolTip="{Binding UpdateMessage}" Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}">
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <Viewbox Width="10" Height="10" Margin="0,0,4,0" VerticalAlignment="Center">
                                                            <Path Data="{StaticResource GArrowUp}" Fill="#FFD580" Stretch="Uniform"/>
                                                        </Viewbox>
                                                        <TextBlock Text="{Binding UpdateTargetDisplay}" FontSize="10" VerticalAlignment="Center" Foreground="#FFD580"/>
                                                    </StackPanel>
                                                </Button>
                                                <ComboBox ItemsSource="{Binding AvailableVersions}"
                                                          SelectedItem="{Binding Version}"
                                                          Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="True"
                                                          Style="{StaticResource CmbSystem}"
                                                          IsEnabled="{Binding IsNotRunning}"
                                                          local:ComboBoxIncrementalLoadingBehavior.LoadMoreCommand="{Binding LoadMoreVersionsCommand}"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                <ToggleButton x:Name="MemoryInputToggle" Style="{StaticResource CompactMemoryFieldVisibility}">
                                    <Viewbox Width="15" Height="15">
                                        <Path Data="{StaticResource GMemoryCard}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                                    </Viewbox>
                                </ToggleButton>
                                <Popup PlacementTarget="{Binding ElementName=MemoryInputToggle}" Placement="Bottom" PopupAnimation="None" StaysOpen="False" IsOpen="{Binding IsChecked, ElementName=MemoryInputToggle, Mode=TwoWay}">
                                    <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.WindowFrameBrushKey}}" BorderThickness="1" Padding="8" Width="180">
                                        <StackPanel>
                                            <TextBlock Text="{x:Static loc:Texts.Xaml_Main_MemoryMb}" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" FontSize="11" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding MaxMemoryMB, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtSystem}" IsEnabled="{Binding IsNotRunning}"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                <ToggleButton x:Name="PortInputToggle" Style="{StaticResource CompactMemoryFieldVisibility}" Margin="0">
                                    <Viewbox Width="15" Height="15">
                                        <Path Data="{StaticResource GPort}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                                    </Viewbox>
                                </ToggleButton>
                                <Popup PlacementTarget="{Binding ElementName=PortInputToggle}" Placement="Bottom" PopupAnimation="None" StaysOpen="False" IsOpen="{Binding IsChecked, ElementName=PortInputToggle, Mode=TwoWay}">
                                    <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.WindowFrameBrushKey}}" BorderThickness="1" Padding="8" Width="170">
                                        <StackPanel>
                                            <TextBlock Text="{x:Static loc:Texts.Xaml_Main_Port}" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" FontSize="11" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtSystem}" IsEnabled="{Binding IsNotRunning}"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>
                        </WrapPanel>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="0"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Button Command="{Binding StartCommand}"
                                    ToolTip="{Binding StartDeniedReason}"
                                    ToolTipService.ShowOnDisabled="True"
                                    Style="{StaticResource BtnPrimary}"
                                    Margin="0,0,6,0">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Viewbox Width="11" Height="11" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <Path Data="{StaticResource GPlay}" Fill="White" Stretch="Uniform"/>
                                        </Viewbox>
                                        <TextBlock Text="{x:Static loc:Texts.Xaml_Main_Start}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding StopCommand}"
                                    ToolTip="{Binding StopDeniedReason}"
                                    ToolTipService.ShowOnDisabled="True"
                                    Style="{StaticResource BtnDanger}"
                                    Margin="0,0,6,0">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Viewbox Width="11" Height="11" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <Path Data="{StaticResource GStop}" Fill="White" Stretch="Uniform"/>
                                        </Viewbox>
                                        <TextBlock Text="{x:Static loc:Texts.Xaml_Main_Stop}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding ManagePluginsCommand}"
                                    ToolTip="{Binding ManagePluginsDeniedReason}"
                                    ToolTipService.ShowOnDisabled="True"
                                    Style="{StaticResource BtnPathOnly}"
                                    Margin="0,0,6,0"
                                    Visibility="{Binding IsPaperServer, Converter={StaticResource BoolToVis}}">
                                    <Viewbox Width="18" Height="18" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GPuzzle}" Fill="#9FCF9F" Stretch="Uniform" Style="{StaticResource PathButtonIcon}"/>
                                    </Viewbox>
                                </Button>
                                <Button Command="{Binding ManageModsCommand}"
                                    ToolTip="{Binding ManageModsDeniedReason}"
                                    ToolTipService.ShowOnDisabled="True"
                                    Style="{StaticResource BtnPathOnly}"
                                    Margin="0,0,6,0"
                                    Visibility="{Binding IsModSupportedServer, Converter={StaticResource BoolToVis}}">
                                    <Viewbox Width="18" Height="18" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GPuzzle}" Fill="#60A0FF" Stretch="Uniform" Style="{StaticResource PathButtonIcon}"/>
                                    </Viewbox>
                                </Button>
                                <Button Command="{Binding EditFilesCommand}"
                                    ToolTip="{Binding EditFilesDeniedReason}"
                                    ToolTipService.ShowOnDisabled="True"
                                    Style="{StaticResource BtnPathOnly}"
                                    Margin="0,0,6,0">
                                    <Viewbox Width="18" Height="18" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GEdit}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform" Style="{StaticResource PathButtonIcon}"/>
                                    </Viewbox>
                                </Button>
                                <Button Command="{Binding OpenFolderCommand}"
                                    ToolTip="{x:Static loc:Texts.Xaml_Main_Folder}"
                                    Style="{StaticResource BtnPathOnly}">
                                    <Viewbox Width="18" Height="18" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GFolder}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform" Style="{StaticResource PathButtonIcon}"/>
                                    </Viewbox>
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=ge:500}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="1"
                                    Padding="8,4" Margin="0,0,6,0">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,5,0">
                                            <Path Data="{StaticResource GCpu}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                                        </Viewbox>
                                        <TextBlock Text="{Binding CpuUsage}" Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="1"
                                    Padding="8,4" Margin="0,0,6,0">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,5,0">
                                            <Path Data="{StaticResource GMemory}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                                        </Viewbox>
                                        <TextBlock Text="{Binding MemoryUsage}" Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="1"
                                    Padding="8,4">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,5,0">
                                            <Path Data="{StaticResource GPerson}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                                        </Viewbox>
                                        <TextBlock Text="{Binding PlayerCount}"
                                               Foreground="#3FB950" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="#3A2E1A"
                    BorderBrush="#8F6A2A"
                    BorderThickness="0,0,0,1"
                    Padding="12,7"
                    Visibility="{Binding HasEulaGuidance, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding EulaGuidanceMessage}"
                           Foreground="#FFD580"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="2"
                    Background="#171D17"
                    BorderBrush="#2A3C2A"
                    BorderThickness="0,0,0,1"
                    Padding="12,6"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0">
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding DownloadProgress, StringFormat={}{0:0}%}"
                                   Foreground="#3FB950" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DownloadStatusText}" Foreground="#3FB950" FontSize="12"/>
                    </DockPanel>
                    <ProgressBar Grid.Row="2"
                                 Value="{Binding DownloadProgress, Mode=OneWay}"
                                 Maximum="100"
                                 Height="8"
                                 Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                                 Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="3">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="*"/>
                                <Setter Property="MinWidth" Value="180"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:860}" Value="True">
                                        <Setter Property="MinWidth" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="4"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:860}" Value="True">
                                        <Setter Property="Width" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="155"/>
                                <Setter Property="MinWidth" Value="100"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:860}" Value="True">
                                        <Setter Property="Width" Value="0"/>
                                        <Setter Property="MinWidth" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Grid.ColumnSpan" Value="1"/>
                            <Setter Property="Grid.RowSpan" Value="3"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:860}" Value="True">
                                    <Setter Property="Grid.ColumnSpan" Value="3"/>
                                    <Setter Property="Grid.RowSpan" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0"
                             x:Name="ConsoleListBox"
                             ItemsSource="{Binding ConsoleLines}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="10,8"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             local:AutoScrollBehavior.AutoScroll="True">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Focusable" Value="False"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ColoredConsoleLine}">
                                <TextBlock Text="{Binding Text}"
                                           Foreground="{Binding Foreground}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,1"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="1" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="0,1,0,0">
                        <Grid Margin="8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" MinWidth="0"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#x276F;"
                                       Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                                       FontFamily="Consolas"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="2,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     local:AutoScrollBehavior.ForceScrollTarget="{Binding ElementName=ConsoleListBox}"
                                     Text="{Binding CurrentCommandInput, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                     CaretBrush="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     VerticalAlignment="Center"
                                     MinWidth="0"
                                     Padding="0,5"
                                     IsEnabled="{Binding IsRunning}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding SendCommandCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="2"
                                    local:AutoScrollBehavior.ForceScrollTarget="{Binding ElementName=ConsoleListBox}"
                                    Command="{Binding SendCommandCommand}"
                                    ToolTip="{Binding SendCommandDeniedReason}"
                                    ToolTipService.ShowOnDisabled="True"
                                    Style="{StaticResource BtnIconGhost}"
                                    Margin="2,0,0,0">
                                <Viewbox Width="13" Height="13">
                                    <Path Data="{StaticResource GSend}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                                </Viewbox>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="1" Grid.Row="0" Grid.RowSpan="3" Width="4" HorizontalAlignment="Stretch"
                              Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" Cursor="SizeWE"
                              ResizeBehavior="PreviousAndNext">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:860}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </GridSplitter.Style>
                </GridSplitter>

                <GridSplitter Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" Cursor="SizeNS"
                              ResizeDirection="Rows" ResizeBehavior="PreviousAndNext">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:860}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </GridSplitter.Style>
                </GridSplitter>

                <Grid Grid.Column="2" Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="Grid.RowSpan" Value="3"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:860}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="0,0,0,1" Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="0"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Viewbox Width="13" Height="13" Margin="0,0,7,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource GPerson}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                                </Viewbox>
                                <TextBlock Text="参加者"
                                           Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" Padding="6,2" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding PlayerCount}"
                                           Foreground="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Players}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="4"
                             ItemContainerStyle="{StaticResource PlayerListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PlayerViewModel}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="24" Height="24" Margin="0,0,8,0"
                                            Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" VerticalAlignment="Center">
                                        <Image Source="{Binding SkinImage}"
                                               Width="24" Height="24"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                                               Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WidthThresholdConverter}, ConverterParameter=lt:860}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="0,1,0,1" Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="0"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Viewbox Width="13" Height="13" Margin="0,0,7,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource GPerson}" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform"/>
                                </Viewbox>
                                <TextBlock Text="参加者"
                                           Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" Padding="6,2" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding PlayerCount}"
                                           Foreground="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Players}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="4"
                             ItemContainerStyle="{StaticResource PlayerListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PlayerViewModel}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="24" Height="24" Margin="0,0,8,0"
                                            Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" VerticalAlignment="Center">
                                        <Image Source="{Binding SkinImage}"
                                               Width="24" Height="24"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                                               Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>