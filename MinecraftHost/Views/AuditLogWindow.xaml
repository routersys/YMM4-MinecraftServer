<Window x:Class="MinecraftHost.Views.AuditLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:MinecraftHost.Localization"
        mc:Ignorable="d"
        Title="{x:Static loc:Texts.Xaml_AuditLog_Title}"
        Height="620"
        Width="980"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{x:Static loc:Texts.Xaml_AuditLog_DisplayCount}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Opacity="0.7"/>
                <TextBox Text="{Binding MaxItems, UpdateSourceTrigger=PropertyChanged}"
                         Width="90"
                         Style="{StaticResource TxtSystem}"/>
                <Button Content="{x:Static loc:Texts.Xaml_Common_Refresh}"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource BtnPrimary}"
                        Margin="10,0,0,0"
                        Padding="12,6"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1"
                  Margin="8"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Entries}"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static loc:Texts.Xaml_AuditLog_HeaderTimestampUtc}" Binding="{Binding TimestampUtc}" Width="180"/>
                <DataGridTextColumn Header="{x:Static loc:Texts.Xaml_AuditLog_HeaderCategory}" Binding="{Binding Category}" Width="140"/>
                <DataGridTextColumn Header="{x:Static loc:Texts.Xaml_AuditLog_HeaderAction}" Binding="{Binding Action}" Width="130"/>
                <DataGridTextColumn Header="{x:Static loc:Texts.Xaml_AuditLog_HeaderEntityId}" Binding="{Binding EntityId}" Width="180"/>
                <DataGridTextColumn Header="{x:Static loc:Texts.Xaml_AuditLog_HeaderProperty}" Binding="{Binding Property}" Width="120"/>
                <DataGridTextColumn Header="{x:Static loc:Texts.Xaml_AuditLog_HeaderBefore}" Binding="{Binding Before}" Width="*"/>
                <DataGridTextColumn Header="{x:Static loc:Texts.Xaml_AuditLog_HeaderAfter}" Binding="{Binding After}" Width="*"/>
                <DataGridTextColumn Header="{x:Static loc:Texts.Xaml_AuditLog_HeaderActor}" Binding="{Binding Actor}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>