<UserControl x:Class="MinecraftHost.Settings.SettingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MinecraftHost.Settings"
             xmlns:loc="clr-namespace:MinecraftHost.Localization"
             mc:Ignorable="d"
             d:DesignHeight="420" d:DesignWidth="500"
             d:DataContext="{d:DesignInstance Type=local:SettingPageViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MainPageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20" MaxWidth="540">

            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_JavaSettings}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                   Margin="0,0,0,16"/>

            <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                Padding="12,10"
                Margin="0,0,0,20">
                <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_JavaDescription}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                       Opacity="0.9"
                       FontSize="12"
                       LineHeight="20"/>
            </Border>

            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_JavaExecutable}"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                   Opacity="0.7"
                   FontSize="11"
                   Margin="0,0,0,5"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                     Text="{Binding JavaPath, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource TxtSystem}"
                     FontFamily="Consolas"
                     FontSize="12"/>
                <Button Grid.Column="2"
                    Content="{x:Static loc:Texts.Xaml_Setting_Browse}"
                    Command="{Binding BrowseCommand}"
                    Style="{StaticResource BtnSecondary}"
                    Padding="12,6"/>
            </Grid>

            <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                Padding="10,8"
                Margin="0,0,0,28">
                <StackPanel Orientation="Horizontal">
                    <Rectangle Width="6" Height="6" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Rectangle.Style>
                            <Style TargetType="Rectangle">
                                <Setter Property="Fill" Value="#C84B1C"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsJavaPathValid}" Value="True">
                                        <Setter Property="Fill" Value="#3FB950"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Rectangle.Style>
                    </Rectangle>
                    <TextBlock Text="{Binding JavaPathStatus}"
                           Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                           Opacity="0.8"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_NetworkSettings}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                   Margin="0,0,0,16"/>

            <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                Padding="14,12"
                Margin="0,0,0,8">
                <StackPanel>
                    <CheckBox Content="{x:Static loc:Texts.Xaml_Setting_EnablePortForwarding}"
                          IsChecked="{Binding EnablePortForwarding}"
                          Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                          Margin="0,0,0,8"/>
                    <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_PortForwardingDescription}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                           Opacity="0.7"
                           FontSize="11"
                           LineHeight="18"
                           Margin="26,0,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_OperationsStability}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                   Margin="0,16,0,16"/>

            <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                Padding="14,12"
                Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_ConsoleLineRetention}"
                           Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                           Opacity="0.7"
                           FontSize="11"
                           Margin="0,0,0,4"/>
                    <TextBox Text="{Binding MaxConsoleLines, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource TxtSystem}"
                         Width="130"
                         HorizontalAlignment="Left"
                         Margin="0,0,0,10"/>

                    <CheckBox Content="{x:Static loc:Texts.Xaml_Setting_EnableAutoRestart}"
                          IsChecked="{Binding EnableAutoRestart}"
                          Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                          Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="26,0,0,0">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_MaxRetryCount}"
                                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                   Opacity="0.7"
                                   FontSize="11"
                                   Margin="0,0,0,4"/>
                            <TextBox Text="{Binding AutoRestartMaxAttempts, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TxtSystem}"
                                 Width="80"
                                 IsEnabled="{Binding EnableAutoRestart}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_RestartDelaySeconds}"
                                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                   Opacity="0.7"
                                   FontSize="11"
                                   Margin="0,0,0,4"/>
                            <TextBox Text="{Binding AutoRestartDelaySeconds, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TxtSystem}"
                                 Width="80"
                                 IsEnabled="{Binding EnableAutoRestart}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_StructuredLog}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                   Margin="0,16,0,16"/>

            <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                Padding="14,12"
                Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_LogDirectory}"
                           Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                           Opacity="0.7"
                           FontSize="11"
                           Margin="0,0,0,4"/>
                    <TextBox Text="{Binding StructuredLogsDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource TxtSystem}"
                         FontFamily="Consolas"
                         FontSize="12"
                         Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_KeepFileCount}"
                                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                   Opacity="0.7"
                                   FontSize="11"
                                   Margin="0,0,0,4"/>
                            <TextBox Text="{Binding StructuredLogMaxFiles, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TxtSystem}"
                                 Width="90"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_MaxFileSizeMb}"
                                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                   Opacity="0.7"
                                   FontSize="11"
                                   Margin="0,0,0,4"/>
                            <TextBox Text="{Binding StructuredLogMaxFileSizeMB, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TxtSystem}"
                                 Width="120"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Content="{x:Static loc:Texts.Xaml_Setting_OpenLogViewer}"
                        Command="{Binding OpenStructuredLogViewerCommand}"
                        Style="{StaticResource BtnSecondary}"
                        HorizontalAlignment="Left"
                        Margin="0,10,0,0"
                        Padding="12,6"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_BackupRestore}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                   Margin="0,16,0,16"/>

            <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                Padding="14,12"
                Margin="0,0,0,8">
                <StackPanel>
                    <CheckBox Content="{x:Static loc:Texts.Xaml_Setting_EnableSafeUpdateBackup}"
                          IsChecked="{Binding EnableSafeUpdateBackup}"
                          Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                          Margin="0,0,0,8"/>
                    <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_BackupRetentionGenerations}"
                           Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                           Opacity="0.7"
                           FontSize="11"
                           Margin="0,0,0,4"/>
                    <TextBox Text="{Binding SafeUpdateBackupRetention, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource TxtSystem}"
                         Width="90"
                         HorizontalAlignment="Left"
                         IsEnabled="{Binding EnableSafeUpdateBackup}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_AuthorizationPolicy}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                   Margin="0,16,0,16"/>

            <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                Padding="14,12"
                Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_OperatorRole}"
                           Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                           Opacity="0.7"
                           FontSize="11"
                           Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailableOperatorRoles}"
                          SelectedItem="{Binding OperatorRole}"
                          Style="{StaticResource CmbSystem}"
                          Width="160"
                          HorizontalAlignment="Left"
                          Margin="0,0,0,10"/>

                    <CheckBox Content="{x:Static loc:Texts.Xaml_Setting_RequireAuthOnRoleElevation}"
                          IsChecked="{Binding RequireRoleElevationAuthentication}"
                          Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                          Margin="0,0,0,6"/>

                    <CheckBox Content="{x:Static loc:Texts.Xaml_Setting_PreferWindowsHello}"
                          IsChecked="{Binding PreferWindowsHelloForRoleElevation}"
                          Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                          Margin="0,0,0,8"
                          IsEnabled="{Binding RequireRoleElevationAuthentication}"/>

                    <StackPanel Orientation="Horizontal" Margin="26,0,0,8">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_CurrentPin}"
                                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                   Opacity="0.7"
                                   FontSize="11"
                                   Margin="0,0,0,4"/>
                            <TextBox Text="{Binding CurrentRoleElevationPin, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TxtSystem}"
                                 Width="120"
                                 IsEnabled="{Binding RequireRoleElevationAuthentication}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_NewPin}"
                                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                   Opacity="0.7"
                                   FontSize="11"
                                   Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewRoleElevationPin, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TxtSystem}"
                                 Width="120"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_NewPinConfirm}"
                                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                   Opacity="0.7"
                                   FontSize="11"
                                   Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ConfirmRoleElevationPin, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TxtSystem}"
                                 Width="140"/>
                        </StackPanel>
                    </StackPanel>

                    <CheckBox Content="{x:Static loc:Texts.Xaml_Setting_EnableMaintenanceMode}"
                          IsChecked="{Binding MaintenanceMode}"
                          Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                          Margin="0,0,0,8"/>

                    <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_LockedTargetServer}"
                           Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                           Opacity="0.7"
                           FontSize="11"
                           Margin="0,0,0,4"/>

                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right"
                            Content="{x:Static loc:Texts.Xaml_Common_Add}"
                            Command="{Binding AddLockedServerCommand}"
                            Style="{StaticResource BtnSecondary}"
                            Padding="12,6"
                            Margin="8,0,0,0"/>
                        <ComboBox ItemsSource="{Binding AvailableServers}"
                              SelectedItem="{Binding SelectedServerToLock}"
                              Style="{StaticResource CmbSystem}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Id}" FontSize="10" Opacity="0.75" FontFamily="Consolas"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </DockPanel>

                    <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                        BorderThickness="1"
                        Padding="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ListBox Grid.Row="0"
                                 ItemsSource="{Binding LockedServers}"
                                 SelectedItem="{Binding SelectedLockedServer}"
                                 MinHeight="110">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Id}" FontSize="10" Opacity="0.75" FontFamily="Consolas"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Button Grid.Row="1"
                                Content="{x:Static loc:Texts.Xaml_Setting_ClearSelection}"
                                Command="{Binding RemoveLockedServerCommand}"
                                Style="{StaticResource BtnDanger}"
                                Padding="12,6"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="{Binding AuthorizationStatus}"
                           Foreground="#FFD580"
                           FontSize="11"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_AuditAndOperations}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                   Margin="0,16,0,16"/>

            <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                Padding="14,12"
                Margin="0,0,0,8">
                <WrapPanel>
                    <Button Content="{x:Static loc:Texts.Xaml_Setting_OpenAuditLog}"
                        Command="{Binding OpenAuditLogViewerCommand}"
                        ToolTip="{Binding OpenAuditLogDeniedReason}"
                        ToolTipService.ShowOnDisabled="True"
                        Style="{StaticResource BtnSecondary}"
                        Margin="0,0,10,0"
                        Padding="12,6"/>
                    <Button Content="{x:Static loc:Texts.Xaml_Setting_OpenOperationsDashboard}"
                        Command="{Binding OpenOperationsCenterCommand}"
                        ToolTip="{Binding OpenOperationsCenterDeniedReason}"
                        ToolTipService.ShowOnDisabled="True"
                        Style="{StaticResource BtnSecondary}"
                        Padding="12,6"/>
                </WrapPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <TextBlock Text="{x:Static loc:Texts.Xaml_Setting_AutoSaveNotice}"
                       Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                       Opacity="0.7"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>
                <Button Content="{x:Static loc:Texts.Xaml_Setting_Clear}"
                    Command="{Binding ClearCommand}"
                    Style="{StaticResource BtnDanger}"
                    Padding="14,7"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>